## Bee Signal Engine
export class BeeSignal {

  calculatePath(nodes) {

      return nodes.sort(
        (a,b)=>a.cost-b.cost
      );

  }

}

## Green Fuel Store
import { create } from "zustand";

export const useEnergyStore = create(
(set)=>({

 solar:80,

 battery:70,

 wind:45,

 updateSolar:(v)=>
   set({solar:v})

}));

