<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Router Sensed Parallel Space</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{background:#020f05;color:#00ff66;font-family:'Courier New',monospace;height:100vh;display:flex;flex-direction:column;overflow:hidden;}
#topbar{display:flex;justify-content:space-between;align-items:center;padding:6px 14px;border-bottom:1px solid #00ff6622;background:#020f05;flex-shrink:0;font-size:9px;letter-spacing:2px;}
.topbar-title{font-size:11px;color:#00ff66;letter-spacing:3px;}
.blink{animation:blink 1s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.2;}}
#app{flex:1;display:flex;gap:0;overflow:hidden;}
/* LEFT MAP */
#mapPanel{flex:1.1;display:flex;flex-direction:column;border-right:1px solid #00ff6622;overflow:hidden;}
#mapHeader{padding:5px 10px;font-size:9px;letter-spacing:3px;color:#00aa44;border-bottom:1px solid #00ff6611;flex-shrink:0;display:flex;justify-content:space-between;}
#mapCanvas{flex:1;width:100%;}
#mapControls{display:flex;gap:6px;padding:6px 10px;border-top:1px solid #00ff6611;flex-shrink:0;flex-wrap:wrap;align-items:center;}
.mbc{font-size:9px;letter-spacing:2px;}
.btn{background:#00ff6611;border:1px solid #00ff6633;color:#00ff66;padding:4px 10px;border-radius:3px;cursor:pointer;font-family:'Courier New',monospace;font-size:9px;letter-spacing:1px;transition:all .15s;}
.btn:hover{background:#00ff6633;box-shadow:0 0 8px #00ff6644;}
.btn.on{background:#00ff6622;border-color:#00ff66;box-shadow:0 0 10px #00ff6655;}
/* RIGHT PANELS */
#rightPanel{flex:0.9;display:flex;flex-direction:column;overflow:hidden;}
/* Socket traffic */
#socketPanel{flex:1;display:flex;flex-direction:column;border-bottom:1px solid #00ff6622;overflow:hidden;}
#socketHeader{padding:5px 10px;font-size:9px;letter-spacing:3px;color:#00aa44;border-bottom:1px solid #00ff6611;flex-shrink:0;display:flex;justify-content:space-between;}
#signalCanvas{height:80px;width:100%;flex-shrink:0;}
#packetLog{flex:1;overflow-y:auto;padding:4px 8px;font-size:9px;line-height:1.6;}
#packetLog::-webkit-scrollbar{width:3px;}
#packetLog::-webkit-scrollbar-thumb{background:#00ff6633;}
.pkt{color:#00cc44;} .pkt span{color:#00ff66;} .pkt.err{color:#ff4444;}
/* Sensor panel */
#sensorPanel{flex:0 0 auto;border-top:1px solid #00ff6622;padding:8px 10px;display:flex;flex-direction:column;gap:6px;}
#sensorHeader{font-size:9px;letter-spacing:3px;color:#00aa44;margin-bottom:2px;}
.sensor-row{display:flex;align-items:center;gap:8px;}
.sensor-lbl{font-size:8px;color:#008833;letter-spacing:1px;width:110px;flex-shrink:0;}
.bar-bg{flex:1;height:5px;background:#00ff6611;border-radius:3px;overflow:hidden;}
.bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#004422,#00ff66);box-shadow:0 0 4px #00ff6655;transition:width .3s;}
.sensor-val{font-size:9px;color:#00ff66;width:48px;text-align:right;flex-shrink:0;}
#statusbar{padding:3px 10px;font-size:8px;color:#00441166;letter-spacing:2px;border-top:1px solid #00ff6611;flex-shrink:0;white-space:nowrap;overflow:hidden;}
</style>
</head>
<body>

<div id="topbar">
  <div class="topbar-title">ROUTER_SENSED_PARALLEL_SPACE</div>
  <div>MOBIUS_TRACKED &nbsp;<span class="blink">◆</span>&nbsp; SOCKET_PORT_RECEIVED</div>
  <div>V_CHANNEL: <span id="vchan">SMOOTH</span> &nbsp;|&nbsp; UPTIME: <span id="uptime">00:00:00</span></div>
</div>

<div id="app">
  <!-- MAP -->
  <div id="mapPanel">
    <div id="mapHeader">
      <span>MOBIUS_MAP :: ROUTE_KNOTS :: BEACON_SILHOUETTE</span>
      <span id="nodeCount">NODES: 0</span>
    </div>
    <canvas id="mapCanvas"></canvas>
    <div id="mapControls">
      <span class="mbc">LAYER:</span>
      <button class="btn on" id="btnRoutes" onclick="toggleLayer('routes')">ROUTES</button>
      <button class="btn on" id="btnBeacons" onclick="toggleLayer('beacons')">BEACONS</button>
      <button class="btn on" id="btnFuel" onclick="toggleLayer('fuel')">GREEN_FUEL</button>
      <button class="btn on" id="btnMobius" onclick="toggleLayer('mobius')">MÖBIUS</button>
      <button class="btn" id="btnRegen" onclick="regenMap()" style="margin-left:auto;">↺ REGEN</button>
    </div>
  </div>

  <!-- RIGHT -->
  <div id="rightPanel">
    <!-- Socket -->
    <div id="socketPanel">
      <div id="socketHeader">
        <span>COMMUTE_SOCKET :: V_ACCENTURE_CHANNEL :: CLOUD_CAPTURE</span>
        <span id="pktCount">PKT: 0</span>
      </div>
      <canvas id="signalCanvas"></canvas>
      <div id="packetLog"></div>
    </div>
    <!-- Sensors -->
    <div id="sensorPanel">
      <div id="sensorHeader">ENVIRONMENTAL_SENSORS :: GREEN_FUEL :: MILE_SKELETON_QUEUE</div>
      <div class="sensor-row"><span class="sensor-lbl">GREEN_FUEL</span><div class="bar-bg"><div class="bar-fill" id="s0" style="width:0%"></div></div><span class="sensor-val" id="sv0">0%</span></div>
      <div class="sensor-row"><span class="sensor-lbl">ROUTE_KNOTS</span><div class="bar-bg"><div class="bar-fill" id="s1" style="width:0%"></div></div><span class="sensor-val" id="sv1">0</span></div>
      <div class="sensor-row"><span class="sensor-lbl">SKELETON_QUEUE</span><div class="bar-bg"><div class="bar-fill" id="s2" style="width:0%"></div></div><span class="sensor-val" id="sv2">0/64</span></div>
      <div class="sensor-row"><span class="sensor-lbl">CLOUD_CAPTURE</span><div class="bar-bg"><div class="bar-fill" id="s3" style="width:0%"></div></div><span class="sensor-val" id="sv3">0 KB</span></div>
      <div class="sensor-row"><span class="sensor-lbl">LINKAGE_SMOOTH</span><div class="bar-bg"><div class="bar-fill" id="s4" style="width:0%"></div></div><span class="sensor-val" id="sv4">0.00</span></div>
    </div>
  </div>
</div>

<div id="statusbar">FLOWER_POT()::BEACONED(SILHOUETTE_QUEUE)::TREE_LEFT_STEMMED::GREEN_FUEL()::CONSOLIDATED_LOCATION_ROUTE_KNOTS.MAP()</div>

<script>
// ── Canvas setup ──────────────────────────────────────────
const mc = document.getElementById('mapCanvas');
const mx = mc.getContext('2d');
const sc = document.getElementById('signalCanvas');
const sx = sc.getContext('2d');
const dpr = window.devicePixelRatio||1;

function resizeAll(){
  mc.width = mc.offsetWidth*dpr; mc.height = mc.offsetHeight*dpr;
  sc.width = sc.offsetWidth*dpr; sc.height = sc.offsetHeight*dpr;
}
resizeAll();
window.addEventListener('resize', resizeAll);

// ── Layers toggle ─────────────────────────────────────────
const layers = {routes:true, beacons:true, fuel:true, mobius:true};
function toggleLayer(l){
  layers[l] = !layers[l];
  document.getElementById('btn'+l.charAt(0).toUpperCase()+l.slice(1)).classList.toggle('on', layers[l]);
}

// ── Map Data ──────────────────────────────────────────────
let nodes=[], edges=[], beacons=[], fuelNodes=[], mobiusPts=[], routeKnots=[];
let mobiusT=0;

function rnd(a,b){return a+Math.random()*(b-a);}
function regenMap(){
  const W=mc.offsetWidth, H=mc.offsetHeight;
  nodes=[];edges=[];beacons=[];fuelNodes=[];routeKnots=[];
  // Skeleton tree nodes
  const root={x:W*0.5,y:H*0.55,id:0};
  nodes.push(root);
  const branches=6+Math.floor(Math.random()*4);
  for(let i=1;i<=branches;i++){
    const angle = (i/branches)*Math.PI*1.6 - 0.3;
    const r = rnd(H*0.18,H*0.38);
    nodes.push({x:root.x+Math.cos(angle)*r, y:root.y-Math.sin(angle)*r*0.7, id:i});
    edges.push([0,i]);
    // sub-branches
    if(Math.random()>.4){
      const sub={x:nodes[i].x+rnd(-80,80),y:nodes[i].y+rnd(-60,60),id:nodes.length};
      nodes.push(sub);
      edges.push([i,sub.id]);
    }
  }
  // Beacons
  beacons=[];
  for(let i=0;i<5;i++) beacons.push({x:rnd(30,W-30),y:rnd(30,H-30),r:0,phase:Math.random()*Math.PI*2,id:'B'+Math.floor(Math.random()*0xFFFF).toString(16).toUpperCase()});
  // Fuel nodes
  fuelNodes=[];
  for(let i=0;i<4;i++) fuelNodes.push({x:rnd(40,W-40),y:rnd(40,H-40),level:rnd(0.3,1)});
  // Route knots (consolidated)
  routeKnots=[];
  for(let i=0;i<8;i++) routeKnots.push({x:rnd(20,W-20),y:rnd(20,H-20),t:Math.random()*Math.PI*2});
  // Möbius path points
  mobiusPts=[];
  const cx=W*0.5,cy=H*0.48;
  for(let i=0;i<=120;i++){
    const t=(i/120)*Math.PI*2;
    const R=Math.min(W,H)*0.22, r2=Math.min(W,H)*0.06;
    const x=cx+(R+r2*Math.cos(t*1.5))*Math.cos(t);
    const y=cy+(R+r2*Math.cos(t*1.5))*Math.sin(t)*0.55;
    mobiusPts.push({x,y});
  }
  document.getElementById('nodeCount').textContent='NODES: '+nodes.length;
}
regenMap();

// ── Draw Map ──────────────────────────────────────────────
function drawMap(){
  const W=mc.width, H=mc.height;
  mx.clearRect(0,0,W,H);
  const s=dpr;

  // Grid
  mx.strokeStyle='#00ff6608'; mx.lineWidth=1;
  for(let x=0;x<W;x+=40*s){mx.beginPath();mx.moveTo(x,0);mx.lineTo(x,H);mx.stroke();}
  for(let y=0;y<H;y+=40*s){mx.beginPath();mx.moveTo(0,y);mx.lineTo(W,y);mx.stroke();}

  // Möbius loop
  if(layers.mobius && mobiusPts.length>1){
    mx.save();
    mx.strokeStyle='#00ff6633'; mx.lineWidth=1.5*s;
    mx.setLineDash([6,4]);
    mx.beginPath();
    mobiusPts.forEach((p,i)=>{ i===0?mx.moveTo(p.x*s,p.y*s):mx.lineTo(p.x*s,p.y*s); });
    mx.stroke();
    mx.setLineDash([]);
    // Möbius tracker dot
    const ti=Math.floor(mobiusT % mobiusPts.length);
    const mp=mobiusPts[ti];
    mx.fillStyle='#00ff66';
    mx.shadowBlur=14; mx.shadowColor='#00ff66';
    mx.beginPath(); mx.arc(mp.x*s,mp.y*s,4*s,0,Math.PI*2); mx.fill();
    mx.shadowBlur=0;
    mx.restore();
  }

  // Routes (tree skeleton)
  if(layers.routes){
    edges.forEach(([a,b])=>{
      const na=nodes[a], nb=nodes[b];
      if(!na||!nb) return;
      mx.strokeStyle='#00ff6644'; mx.lineWidth=1.2*s;
      mx.beginPath(); mx.moveTo(na.x*s,na.y*s); mx.lineTo(nb.x*s,nb.y*s); mx.stroke();
      // animate packet on edge
      const pt=((Date.now()/800 + a*0.3)%1);
      const px=(na.x+(nb.x-na.x)*pt)*s, py=(na.y+(nb.y-na.y)*pt)*s;
      mx.fillStyle='#00ff66'; mx.shadowBlur=8; mx.shadowColor='#00ff66';
      mx.beginPath(); mx.arc(px,py,2.5*s,0,Math.PI*2); mx.fill();
      mx.shadowBlur=0;
    });
    // Nodes
    nodes.forEach(n=>{
      mx.fillStyle='#041208'; mx.strokeStyle='#00ff66'; mx.lineWidth=1.5*s;
      mx.beginPath(); mx.arc(n.x*s,n.y*s,5*s,0,Math.PI*2); mx.fill(); mx.stroke();
    });
  }

  // Route knots
  if(layers.routes){
    routeKnots.forEach(k=>{
      k.t+=0.018;
      const r=6+Math.sin(k.t)*3;
      mx.strokeStyle='#00ff6655'; mx.lineWidth=1*s;
      mx.beginPath(); mx.arc(k.x*s,k.y*s,r*s,0,Math.PI*2); mx.stroke();
      mx.strokeStyle='#00ff6622';
      mx.beginPath(); mx.arc(k.x*s,k.y*s,(r+5)*s,0,Math.PI*2); mx.stroke();
    });
  }

  // Green Fuel nodes
  if(layers.fuel){
    fuelNodes.forEach(f=>{
      const r=10*s;
      mx.fillStyle='#004422'; mx.strokeStyle='#00ff66';
      mx.lineWidth=1.5*s; mx.shadowBlur=12; mx.shadowColor='#00ff6688';
      mx.beginPath(); mx.arc(f.x*s,f.y*s,r,0,Math.PI*2); mx.fill(); mx.stroke();
      mx.shadowBlur=0;
      // fuel level arc
      mx.strokeStyle='#00ff66'; mx.lineWidth=3*s;
      mx.beginPath(); mx.arc(f.x*s,f.y*s,r,-Math.PI/2,-Math.PI/2+f.level*Math.PI*2); mx.stroke();
      mx.fillStyle='#00ff66'; mx.font=`${8*s}px Courier New`;
      mx.textAlign='center'; mx.fillText('⚡',f.x*s,f.y*s+3*s);
    });
  }

  // Beacons
  if(layers.beacons){
    beacons.forEach(b=>{
      b.r=(b.r+0.7)%80;
      b.phase+=0.03;
      // rings
      [0.3,0.6,1].forEach((frac,ri)=>{
        const br=(b.r+ri*26)%80;
        const alpha=Math.max(0,0.5-br/80);
        mx.strokeStyle=`rgba(0,255,102,${alpha})`;
        mx.lineWidth=1*s;
        mx.beginPath(); mx.arc(b.x*s,b.y*s,br*s,0,Math.PI*2); mx.stroke();
      });
      // center
      mx.fillStyle='#00ff66'; mx.shadowBlur=16; mx.shadowColor='#00ff66';
      mx.beginPath(); mx.arc(b.x*s,b.y*s,4*s,0,Math.PI*2); mx.fill();
      mx.shadowBlur=0;
      // silhouette label
      mx.fillStyle='#00cc4488'; mx.font=`${7*s}px Courier New`;
      mx.textAlign='left'; mx.fillText(b.id,b.x*s+7*s,b.y*s-4*s);
    });
  }
}

// ── Signal Graph ──────────────────────────────────────────
const sigBuf=new Array(200).fill(0);
let sigSmooth=0;
function pushSignal(v){ sigBuf.push(v); if(sigBuf.length>200) sigBuf.shift(); }

function drawSignal(){
  const W=sc.width, H=sc.height;
  sx.clearRect(0,0,W,H);
  sx.fillStyle='#020f05';sx.fillRect(0,0,W,H);
  // grid
  sx.strokeStyle='#00ff6610'; sx.lineWidth=1;
  for(let i=0;i<4;i++){const y=H*i/3;sx.beginPath();sx.moveTo(0,y);sx.lineTo(W,y);sx.stroke();}
  // signal
  sx.strokeStyle='#00ff66'; sx.lineWidth=1.5*dpr;
  sx.shadowBlur=8; sx.shadowColor='#00ff66';
  sx.beginPath();
  sigBuf.forEach((v,i)=>{
    const x=(i/sigBuf.length)*W;
    const y=H/2 - v*H*0.35;
    i===0?sx.moveTo(x,y):sx.lineTo(x,y);
  });
  sx.stroke(); sx.shadowBlur=0;
  // smooth line
  sx.strokeStyle='#00ff6644'; sx.lineWidth=1*dpr;
  sx.beginPath();
  sigBuf.forEach((v,i)=>{
    const x=(i/sigBuf.length)*W;
    sigSmooth=sigSmooth*0.92+v*0.08;
    const y=H/2-sigSmooth*H*0.35;
    i===0?sx.moveTo(x,y):sx.lineTo(x,y);
  });
  sx.stroke();
}

// ── Packet Log ────────────────────────────────────────────
let pktCount=0, cloudKB=0;
const log=document.getElementById('packetLog');
const PKT_TYPES=['ROUTE_UPDATE','BEACON_ACK','FUEL_SYNC','KNOT_MAP','SKELETON_PUSH','CLOUD_CAPTURE','LINKAGE_OK','V_CHANNEL'];
const PORTS=[3001,4022,5080,8833,9001,7700];

function addPacket(){
  if(pktCount>999) return;
  pktCount++;
  const type=PKT_TYPES[Math.floor(Math.random()*PKT_TYPES.length)];
  const port=PORTS[Math.floor(Math.random()*PORTS.length)];
  const size=Math.floor(Math.random()*512+64);
  cloudKB+=size/1024;
  const isErr=Math.random()<0.04;
  const div=document.createElement('div');
  div.className='pkt'+(isErr?' err':'');
  const ts=new Date().toISOString().substr(11,12);
  div.innerHTML=`[${ts}] <span>${type}</span> port:${port} seq:${pktCount} ${size}B ${isErr?'⚠ ERR':'✓'}`;
  log.appendChild(div);
  if(log.children.length>80) log.removeChild(log.firstChild);
  log.scrollTop=log.scrollHeight;
  document.getElementById('pktCount').textContent='PKT: '+pktCount;
}

// ── Sensors update ────────────────────────────────────────
let skQueue=0, linkSmooth=0;
function updateSensors(){
  // green fuel avg
  const fuelAvg = fuelNodes.reduce((a,f)=>a+f.level,0)/Math.max(fuelNodes.length,1);
  fuelNodes.forEach(f=>{ f.level=Math.max(0.1,Math.min(1,f.level+(Math.random()-0.5)*0.02)); });
  setSensor(0, fuelAvg*100, (fuelAvg*100).toFixed(1)+'%');

  // route knots count
  setSensor(1, (routeKnots.length/12)*100, routeKnots.length+' knots');

  // skeleton queue
  skQueue=Math.min(64,skQueue+(Math.random()>0.5?1:-1));
  skQueue=Math.max(0,skQueue);
  setSensor(2, (skQueue/64)*100, skQueue+'/64');

  // cloud capture
  setSensor(3, Math.min(100,cloudKB/5*100), cloudKB.toFixed(2)+' KB');

  // linkage smooth
  linkSmooth=linkSmooth*0.9+Math.random()*0.1;
  setSensor(4, linkSmooth*100, linkSmooth.toFixed(3));
}
function setSensor(i,pct,lbl){
  document.getElementById('s'+i).style.width=pct+'%';
  document.getElementById('sv'+i).textContent=lbl;
}

// ── Uptime ────────────────────────────────────────────────
const startTime=Date.now();
function updateUptime(){
  const s=Math.floor((Date.now()-startTime)/1000);
  const h=String(Math.floor(s/3600)).padStart(2,'0');
  const m=String(Math.floor((s%3600)/60)).padStart(2,'0');
  const sec=String(s%60).padStart(2,'0');
  document.getElementById('uptime').textContent=`${h}:${m}:${sec}`;
}

// ── Main loop ─────────────────────────────────────────────
let frame=0;
function loop(){
  frame++;
  mobiusT+=0.4;

  // Signal
  const sig=Math.sin(frame*0.08)*0.6+Math.sin(frame*0.13)*0.3+(Math.random()-0.5)*0.15;
  pushSignal(sig);

  drawMap();
  drawSignal();

  if(frame%18===0){ addPacket(); updateSensors(); }
  if(frame%60===0) updateUptime();

  requestAnimationFrame(loop);
}
loop();
</script>
</body>
</html>
